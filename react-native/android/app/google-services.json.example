{
  "_comment": "Replace this file with the real Firebase Android CLIENT config downloaded from Firebase Console → Project settings → Your apps. Save it as google-services.json (this example file is not used by Gradle). Package name must be com.zixflow.demo. Do NOT put a service-account JSON (type: service_account / private_key) here — that belongs in the Zixflow dashboard only.",
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "project_id": "YOUR_PROJECT_ID",
    "storage_bucket": "YOUR_PROJECT_ID.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "1:YOUR_PROJECT_NUMBER:android:YOUR_APP_ID",
        "android_client_info": {
          "package_name": "com.zixflow.demo"
        }
      },
      "oauth_client": [],
      "api_key": [
        {
          "current_key": "YOUR_ANDROID_API_KEY"
        }
      ],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}
